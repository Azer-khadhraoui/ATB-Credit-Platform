# Copy this file to ".env" and adjust values before running `docker compose up`.
# ".env" is gitignored — never commit real secrets.

MONGO_DATABASE=atb_credit_platform

# Minimum 32 characters (HS256 requirement).
JWT_SECRET=atb-credit-platform-dev-secret-key-change-me-in-production-2026
JWT_EXPIRATION=86400000
